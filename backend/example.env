# Server Configuration
PORT=8000

# Database Configuration (MongoDB Atlas or local)
# If set, this is used in both development and production.
# Example Atlas: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=YourApp
MONGODB_URI=your-mongodb-connection-string

